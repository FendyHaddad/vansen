{
  // IDE-only config: lets the editor type-check Deno edge functions without
  // inheriting the Angular root tsconfig (which flags Deno specifiers, dot
  // access on index signatures, etc.). Deno/Supabase deploys ignore this file.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true
  }
}
